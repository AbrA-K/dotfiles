#!/bin/bash

# this sets up my monitors (and wallpapers) - adjust to your monitors

# hyprctl keyword monitor eDP-1,preferred,auto,1.15

hyprctl keyword monitor "DP-1,1920x1080@144, auto, 1"
hyprctl --batch "keyword monitor HDMI-A-1,prefered,1920x0,1;\
                  keyword monitor HDMI-A-1, transform, 1"

swaybg -i ~/.config/hypr/green-house.png
